# NimbusCMS environment. Copy to .env and adjust.
APP_NAME="NimbusCMS"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8080
# 32-byte base64 key; generate with: php bin/nimbus key:generate
APP_KEY=

DB_HOST=db
DB_PORT=3306
DB_NAME=nimbus
DB_USER=nimbus
DB_PASS=nimbus

# Addresses allowed to set X-Forwarded-For / X-Forwarded-Proto, comma separated.
# Leave EMPTY unless NimbusCMS sits behind a proxy you control — forwarded
# headers are ignored entirely when this is blank, because anyone can send them.
# Accepts plain IPs and CIDR blocks, e.g. the Docker bridge: 172.16.0.0/12
TRUSTED_PROXIES=

# where uploaded media is stored (under the web root so it's served directly)
UPLOAD_DIR=public/uploads
UPLOAD_URL=/uploads
